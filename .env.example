# 交易中心后端环境变量配置模板
# 复制此文件为 .env 并修改对应值

# ═══════════════════════════════════════
# 必需配置
# ═══════════════════════════════════════

# JWT 密钥（必须配置，建议使用32位以上随机字符串）
JWT_SECRET=your-jwt-secret-key-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 加密密钥（用于敏感数据加密，建议16位以上）
ENCRYPTION_KEY=your-encryption-key-16chars

# ═══════════════════════════════════════
# 管理员账号（首次启动自动创建）
# ═══════════════════════════════════════

# 管理员邮箱
ADMIN_EMAIL=admin@yourcompany.com

# 管理员密码（至少8位，需包含大小写字母和数字）
ADMIN_PASSWORD=YourPassword123

# 管理员/公司名称
ADMIN_NAME=您的公司名称

# ═══════════════════════════════════════
# 服务配置
# ═══════════════════════════════════════

# 服务器端口
PORT=3001

# 运行环境 (development / production)
NODE_ENV=development

# 前端地址（CORS 配置）
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════
# 可选配置
# ═══════════════════════════════════════

# 快递100 API（物流查询）
KUAIDI100_KEY=
KUAIDI100_CUSTOMER=

# SMTP 邮箱配置（邮件通知）
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
